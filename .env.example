DATABASE_URL="postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/dbname?sslmode=require"

# BetterAuth secret for signing sessions/tokens (min 32 chars, generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET="change-me-to-a-random-secret-in-production"

# Base URL where the app is served (used by BetterAuth for callbacks)
BETTER_AUTH_URL="http://localhost:3000"

